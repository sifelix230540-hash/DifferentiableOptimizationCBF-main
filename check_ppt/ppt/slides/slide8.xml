0" cy="1166153"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/></p:spPr><p:txBody><a:bodyPr wrap="square" rtlCol="0"><a:spAutoFit/></a:bodyPr><a:lstStyle/><a:p><a:pPr><a:lnSpc><a:spcPct val="150000"/></a:lnSpc></a:pPr><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" b="1" dirty="0"/><a:t>问题：</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" dirty="0"/><a:t>传统</a:t></a:r><a:r><a:rPr lang="en-US" altLang="zh-CN" sz="1200" dirty="0"/><a:t>CBF-QP</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" dirty="0"/><a:t>方法属于</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" b="1" dirty="0"/><a:t>单步预测</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" dirty="0"/><a:t>，反应</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" b="1" dirty="0"/><a:t>速度快但是短视</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" dirty="0"/><a:t>，面对高速移动的障碍物容易产生剧烈的防撞动作损害设备；在多障碍物</a:t></a:r><a:r><a:rPr lang="en-US" altLang="zh-CN" sz="1200" dirty="0"/><a:t>-</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" dirty="0"/><a:t>形状复杂</a:t></a:r><a:r><a:rPr lang="en-US" altLang="zh-CN" sz="1200" dirty="0"/><a:t>-</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" dirty="0"/><a:t>安全空间狭小的场景下模型无解。</a:t></a:r><a:endParaRPr lang="en-US" altLang="zh-CN" sz="1200" dirty="0"/></a:p><a:p><a:pPr><a:lnSpc><a:spcPct val="150000"/></a:lnSpc></a:pPr><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" b="1" dirty="0"/><a:t>方法：</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" dirty="0"/><a:t>将</a:t></a:r><a:r><a:rPr lang="en-US" altLang="zh-CN" sz="1200" dirty="0"/><a:t>CBF-QP</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" dirty="0"/><a:t>安全约束加入</a:t></a:r><a:r><a:rPr lang="en-US" altLang="zh-CN" sz="1200" dirty="0"/><a:t>MPC</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" dirty="0"/><a:t>单步约束之中，从单步预测变为多步预测；自适应化单步</a:t></a:r><a:r><a:rPr lang="en-US" altLang="zh-CN" sz="1200" dirty="0"/><a:t>CBF-QP</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" dirty="0"/><a:t>问题中的约束参数，并将其作为</a:t></a:r><a:r><a:rPr lang="en-US" altLang="zh-CN" sz="1200" dirty="0"/><a:t>MPC</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" dirty="0"/><a:t>优化目标，从而在空间狭小时采用更大的衰减值，空间充裕时采用更小的衰减值。</a:t></a:r></a:p></p:txBody></p:sp></p:spTree><p:custDataLst><p:tags r:id="rId1"/></p:custDataLst></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr><p:timing><p:tnLst><p:par><p:cTn id="1" dur="indefinite" restart="never" nodeType="tmRoot"><p:childTnLst><p:seq concurrent="1" nextAc="seek"><p:cTn id="2" dur="indefinite" nodeType="mainSeq"><p:childTnLst><p:par><p:cTn id="3" fill="hold"><p:stCondLst><p:cond delay="indefinite"/></p:stCondLst><p:childTnLst><p:par><p:cTn id="4" fill="hold"><p:stCondLst><p:cond delay="0"/></p:stCondLst><p:childTnLst><p:par><p:cTn id="5" presetID="1" presetClass="mediacall" presetSubtype="0" fill="hold" nodeType="clickEffect"><p:stCondLst><p:cond delay="0"/></p:stCondLst><p:childTnLst><p:cmd type="call" cmd="playFrom(0.0)"><p:cBhvr><p:cTn id="6" dur="5400" fill="hold"/><p:tgtEl><p:spTgt spid="2"/></p:tgtEl></p:cBhvr></p:cmd></p:childTnLst></p:cTn></p:par></p:childTnLst></p:cTn></p:par></p:childTnLst></p:cTn></p:par><p:par><p:cTn id="7" fill="hold"><p:stCondLst><p:cond delay="indefinite"/></p:stCondLst><p:childTnLst><p:par><p:cTn id="8" fill="hold"><p:stCondLst><p:cond delay="0"/></p:stCondLst><p:childTnLst><p:par><p:cTn id="9" presetID="1" presetClass="mediacall" presetSubtype="0" fill="hold" nodeType="clickEffect"><p:stCondLst><p:cond delay="0"/></p:stCondLst><p:childTnLst><p:cmd type="call" cmd="playFrom(0.0)"><p:cBhvr><p:cTn id="10" dur="18800" fill="hold"/><p:tgtEl><p:spTgt spid="8"/></p:tgtEl></p:cBhvr></p:cmd></p:childTnLst></p:cTn></p:par></p:childTnLst></p:cTn></p:par></p:childTnLst></p:cTn></p:par></p:childTnLst></p:cTn><p:prevCondLst><p:cond evt="onPrev" delay="0"><p:tgtEl><p:sldTgt/></p:tgtEl></p:cond></p:prevCondLst><p:n